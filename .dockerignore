# Keep the service image small, and keep secrets out of it entirely.
.env
.env.local
*.env

.git/
.venv/
venv/

web/
# but keep the published report - the service serves it and the bot sends it.
# Docker needs each parent level re-included, not just the file.
!web/data/
!web/data/report.json
node_modules/
.next/

runs/
harness/**/*.egg-info/
**/__pycache__/
**/.pytest_cache/
*.pyc

.github/
*.md
